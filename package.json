{
  "name": "stream-diffs",
  "type": "module",
  "version": "0.0.2",
  "description": "Lightweight, stream-native code and diff rendering for AI output, powered by @pierre/diffs and Shiki.",
  "author": "Simon He",
  "license": "MIT",
  "homepage": "https://github.com/Simon-He95/stream-diffs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Simon-He95/stream-diffs.git"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./markstream": {
      "types": "./dist/markstream.d.mts",
      "import": "./dist/markstream.mjs"
    },
    "./vue": {
      "types": "./dist/vue.d.mts",
      "import": "./dist/vue.mjs"
    },
    "./pierre": {
      "types": "./dist/pierre.d.mts",
      "import": "./dist/pierre.mjs"
    }
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "docs",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "example": "vite examples",
    "example:build": "vite build examples --outDir ../.tmp/example --emptyOutDir",
    "test": "vitest --run",
    "benchmark": "vitest bench --run benchmarks/streaming.bench.ts",
    "typecheck": "tsc --noEmit",
    "size:check": "node scripts/check-size.mjs",
    "release:verify": "pnpm typecheck && pnpm test && pnpm build && pnpm size:check && pnpm example:build && node scripts/check-package.mjs",
    "release": "bumpp --execute \"pnpm release:publish\"",
    "release:publish": "pnpm build && pnpm publish --no-git-checks"
  },
  "dependencies": {
    "@pierre/diffs": "^1.2.12"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "bumpp": "^11.1.0",
    "jsdom": "^26.1.0",
    "tsdown": "^0.22.7",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vitest": "^3.2.7",
    "vue": "^3.5.39"
  },
  "packageManager": "pnpm@10.34.5"
}
